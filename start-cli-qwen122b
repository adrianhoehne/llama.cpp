#!/usr/bin/env bash
set -euo pipefail

cd /home/adrian/llama.exp

PROFILE="${1:-tuned}"

export LLAMA_ARG_HF_REPO="unsloth/Qwen3.5-122B-A10B-GGUF:IQ3_XXS"
export LLAMA_ARG_DEVICE="CUDA0"
export LLAMA_OFFLINE=1
export LLAMA_LOG_VERBOSITY="${LLAMA_LOG_VERBOSITY:-3}"

export LLAMA_ARG_CTX_SIZE=100000
export LLAMA_ARG_N_PARALLEL=1
export LLAMA_ARG_BATCH="${LLAMA_ARG_BATCH:-2048}"
export LLAMA_ARG_UBATCH="${LLAMA_ARG_UBATCH:-512}"
export LLAMA_ARG_CACHE_RAM="${LLAMA_ARG_CACHE_RAM:-0}"

export LLAMA_ARG_CPU_MOE=1
export LLAMA_ARG_N_GPU_LAYERS=999
export LLAMA_ARG_KV_OFFLOAD=1
export LLAMA_ARG_FLASH_ATTN=on
export LLAMA_ARG_MMPROJ_OFFLOAD=0

export LLAMA_ARG_MOE_HOT_CACHE="${LLAMA_ARG_MOE_HOT_CACHE:-/home/adrian/llama.exp/qwen122b-experts.json}"
export LLAMA_ARG_MOE_HOT_CACHE_MAX_MIB=-1
export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB="${LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB:-768}"
export LLAMA_ARG_MOE_HOT_CACHE_LAYER_CURVE=0.7
export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING="${LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING:-flat}"

export LLAMA_MOE_HOT_CACHE_PARALLEL="${LLAMA_MOE_HOT_CACHE_PARALLEL:-1}"
export LLAMA_MOE_HOT_CACHE_PARALLEL_MIN_SLOTS="${LLAMA_MOE_HOT_CACHE_PARALLEL_MIN_SLOTS:-0}"
export LLAMA_MOE_LAYER_PERF="${LLAMA_MOE_LAYER_PERF:-off}"

export LLAMA_CHAT_TEMPLATE_KWARGS='{"preserve_thinking": true}'
export LLAMA_ARG_REASONING=auto
export LLAMA_ARG_THINK_BUDGET=8096
export LLAMA_ARG_THINK_BUDGET_MESSAGE="Enough thinking, let's jump into it."

CLI_ARGS=()

case "${PROFILE}" in
  tuned)
    ;;
  safe-1024)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=1024
    ;;
  legacy-weighting)
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=pressure
    ;;
  time-035)
    export LLAMA_ARG_MOE_HOT_CACHE_LAYER_CURVE=0.35
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=time
    ;;
  time-050)
    export LLAMA_ARG_MOE_HOT_CACHE_LAYER_CURVE=0.50
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=time
    ;;
  smooth)
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=smooth
    ;;
  smooth-020)
    export LLAMA_ARG_MOE_HOT_CACHE_LAYER_CURVE=0.20
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=smooth
    ;;
  smooth-025)
    export LLAMA_ARG_MOE_HOT_CACHE_LAYER_CURVE=0.25
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=smooth
    ;;
  smooth-035)
    export LLAMA_ARG_MOE_HOT_CACHE_LAYER_CURVE=0.35
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=smooth
    ;;
  smooth-050)
    export LLAMA_ARG_MOE_HOT_CACHE_LAYER_CURVE=0.50
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=smooth
    ;;
  balanced)
    export LLAMA_ARG_MOE_HOT_CACHE_WEIGHTING=balanced
    ;;
  reserve-768)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=768
    ;;
  reserve-640)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=640
    ;;
  reserve-512)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=512
    ;;
  parallel-off)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=768
    export LLAMA_MOE_HOT_CACHE_PARALLEL=0
    ;;
  min-slots-0)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=768
    export LLAMA_MOE_HOT_CACHE_PARALLEL_MIN_SLOTS=0
    ;;
  min-slots-4)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=768
    export LLAMA_MOE_HOT_CACHE_PARALLEL_MIN_SLOTS=4
    ;;
  threads-8)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=768
    export LLAMA_ARG_THREADS=8
    export LLAMA_ARG_THREADS_BATCH=8
    ;;
  no-mmproj)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=768
    CLI_ARGS+=(--no-mmproj)
    ;;
  no-mmap)
    export LLAMA_ARG_MOE_HOT_CACHE_AUTO_RESERVE_MIB=768
    CLI_ARGS+=(--no-mmap)
    ;;
  *)
    echo "unknown profile: ${PROFILE}" >&2
    echo "profiles: tuned, safe-1024, legacy-weighting, time-035, time-050, smooth, smooth-020, smooth-025, smooth-035, smooth-050, balanced, reserve-768, reserve-640, reserve-512, parallel-off, min-slots-0, min-slots-4, threads-8, no-mmproj, no-mmap" >&2
    exit 2
    ;;
esac

PROMPT="${PROMPT:-Erstelle ein Hello World mit HTML und JavaScript}"
N_PREDICT="${2:-${N_PREDICT:-512}}"
LOG_FILE="${LOG_FILE:-/home/adrian/llama.exp/qwen122b-cli-${PROFILE}-$(date +%Y%m%d-%H%M%S).log}"

echo "profile ${PROFILE}"
echo "writing log to ${LOG_FILE}"

exec /home/adrian/llama.exp/build/bin/llama-cli \
  --show-timings \
  --temperature 0.6 \
  "${CLI_ARGS[@]}" \
  -p "${PROMPT}" \
  -n "${N_PREDICT}" \
  -st \
  2>&1 | tee "${LOG_FILE}"
